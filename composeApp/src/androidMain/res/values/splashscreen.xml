<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MyApp.Starting" parent="Theme.SplashScreen">
        <!-- Background color of the splash screen -->
        <item name="windowSplashScreenBackground">@color/background</item>

        <!-- Animated icon shown on the splash screen -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/roundicon</item>

        <item name="windowSplashScreenIconBackgroundColor">@android:color/white</item>

        <item name="windowSplashScreenAnimationDuration">500</item>

        <item name="postSplashScreenTheme">@android:style/Theme.Material.NoActionBar</item>

    </style>
</resources>